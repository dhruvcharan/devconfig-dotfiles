theme = "Nord Wave"
# Alternative Light Theme (Comment out the one above to use this)
# theme = "catppuccin-latte"

font-thicken = true
cursor-style-blink = false
link-url = true
window-inherit-working-directory = true
window-inherit-font-size = true
window-theme = system
clipboard-trim-trailing-spaces = true
mouse-hide-while-typing = true
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = hidden
macos-icon = custom-style
macos-icon-frame = plastic
macos-icon-ghost-color = FFFFFF
macos-icon-screen-color = 000000

# Window Appearance
background-opacity = 0.85
background-blur-radius = 20
window-padding-x = 4
window-padding-y = 4

# Compatibility & QoL
macos-option-as-alt = left
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# -- Conflict-Free Split Navigation (Cmd + Option + Arrows) --
# This prevents conflicts with Neovim's Ctrl+h/j/k/l
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:top
keybind = cmd+alt+down=goto_split:bottom

# -- Precise Split Resizing (Cmd + Shift + Arrows) --
keybind = cmd+shift+left=resize_split:left,20
keybind = cmd+shift+right=resize_split:right,20
keybind = cmd+shift+up=resize_split:up,20
keybind = cmd+shift+down=resize_split:down,20

# -- Advanced Split Management --
keybind = cmd+enter=toggle_split_zoom
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+w=close_surface
keybind = cmd+t=new_tab

# -- Config & Utility --
keybind = cmd+shift+r=reload_config
keybind = cmd+comma=open_config
